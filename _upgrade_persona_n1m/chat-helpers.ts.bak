export type ChatMsg = { role: "system" | "user" | "assistant"; content: string };

const TOKENS_ESTIMATED_PER_CHAR = 0.25;

export function trimHistory(messages: ChatMsg[], maxTokens = 2200): ChatMsg[] {
  if (!messages?.length) return [];
  const kept: ChatMsg[] = [];
  let budget = maxTokens;

  const last = messages[messages.length - 1];
  budget -= estimateTokens(last.content);
  kept.unshift(last);

  for (let i = messages.length - 2; i >= 0; i--) {
    const m = messages[i];
    const t = estimateTokens(m.content);
    if (t <= budget) {
      kept.unshift(m);
      budget -= t;
    } else {
      break;
    }
  }
  return kept;
}

export function sanitizeMessageContent(text: string) {
  // Normaliza espacios raros y recorta extremos, evita caracteres de control
  const safe = (text || "")
    .replace(/[\u0000-\u001f\u007f]/g, " ")
    .replace(/\s+\n/g, "\n")
    .replace(/\n{3,}/g, "\n\n")
    .trim();
  return safe.slice(0, 5000); // hard cap por mensaje
}

function estimateTokens(text: string) {
  return Math.ceil((text || "").length * TOKENS_ESTIMATED_PER_CHAR);
}
