/* ✨ Pulse Chat v0.3 – Pulse a la izquierda, chips plata a la derecha */

.chat-layout {
  display: flex;
  flex-direction: row;
  gap: 1.5rem;
  min-height: 100vh;
  padding: 1.5rem;
  background:
    radial-gradient(1000px 500px at 15% -10%, rgba(56,189,248,0.08), transparent 60%),
    radial-gradient(900px 500px at 85% 110%, rgba(88,28,135,0.10), transparent 55%),
    linear-gradient(180deg, #0b1020, #000000);
}

/* Columna izquierda: Pulse */
.pulse-avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  width: 90px;
}
.pulse-avatar img {
  width: 72px;
  height: 72px;
  object-fit: contain;
  filter: drop-shadow(0 8px 18px rgba(56,189,248,0.35));
}
.pulse-avatar .bubble {
  font-size: .8rem;
  color: #F8FAFC;
  opacity: .85;
  margin-top: .5rem;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.18);
  padding: .4rem .6rem;
  border-radius: .6rem;
  text-align: center;
  backdrop-filter: blur(6px);
}

/* Columna central: Chat */
.chat-panel {
  flex: 1;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 1rem;
  padding: 1rem;
  background: rgba(0,0,0,0.85);
  display: flex;
  flex-direction: column;
}
.chat-bubble-pulse {
  color: #fff;
  border-radius: 1rem;
  padding: 0.75rem;
  margin-bottom: 0.5rem;
  max-width: 80%;
  border: 1px solid #38BDF8;
  background: rgba(56,189,248,0.18);
}
.chat-bubble-user {
  color: #F8FAFC;
  border-radius: 1rem;
  padding: 0.75rem;
  margin-bottom: 0.5rem;
  margin-left: auto;
  max-width: 80%;
  border: 1px solid rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.06);
}
.chat-input {
  width: 100%;
  padding: 0.75rem 1rem;
  border-radius: 1rem;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border: 1px solid #FFD700;
  outline: none;
}
.chat-input::placeholder { color: #d1d5db; }
.chat-input:focus {
  box-shadow: 0 0 12px #38BDF8;
  border-color: #38BDF8;
}
.chat-button {
  font-weight: 700;
  color: #fff;
  padding: 0.75rem 1.25rem;
  border-radius: 1rem;
  background: linear-gradient(90deg,#FFD700,#FF9F45);
  box-shadow: 0 0 16px rgba(56,189,248,0.55);
  border: none;
  cursor: pointer;
}
.chat-button:hover { transform: scale(1.05); }
.chat-button:active { transform: scale(0.95); }

/* Columna derecha: Generador */
.generator-card {
  width: 320px;
  padding: 1rem;
  border-radius: 1rem;
  background: rgba(10,10,20,0.9);
  border: 1px solid rgba(255,255,255,0.1);
  display: flex;
  flex-direction: column;
}
.chips-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: .6rem;
}
.chip-button {
  display: flex;
  align-items: center;
  gap: .6rem;
  width: 100%;
  font-weight: 700;
  color: #0A0A0A;
  padding: .7rem 1rem;
  border-radius: 9999px;
  background: linear-gradient(180deg, #f5f7fa, #dfe6ee);
  border: 1px solid rgba(255,255,255,0.7);
  box-shadow: 0 6px 16px rgba(0,0,0,0.25), 0 0 18px rgba(56,189,248,0.25);
}
.chip-emoji {
  display: inline-grid;
  place-items: center;
  width: 26px;
  height: 26px;
  border-radius: 9999px;
  background: radial-gradient(circle at 30% 30%, #ffffff, #e5edf6);
}

/* Preview */
.preview-box {
  margin-top: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  border-radius: 1rem;
  background: rgba(5,8,15,0.9)
    url('/banner/banner-spark-overlay.png') center/cover no-repeat;
  border: 1px solid rgba(255,255,255,0.18);
  min-height: 200px;
}
