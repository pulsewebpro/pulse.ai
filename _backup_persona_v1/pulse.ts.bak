import type { NextApiRequest, NextApiResponse } from "next";
import { sectorize, respondLocal } from "../../lib/pulseBrain";
import { isOffTopic, offtopicReply } from "../../lib/pulsePolicy";
import { craftHumanReply } from "../../lib/humanizer";

type ApiOut = {
  mode: "live" | "local" | "local_error" | "local_catch" | "offtopic";
  state: "feedback" | "cierre" | "error";
  text: string;
  mood: "neutral" | "celebrate" | "oops";
  meta?: { sector?: string | null; next_step?: string | null } | null;
};

export default async function handler(req: NextApiRequest, res: NextApiResponse<ApiOut>) {
  try {
    const body = typeof req.body === "string" ? JSON.parse(req.body) : (req.body || {});
    const userMsg = String(body.message || "").trim();

    const apiKey = process.env.OPENAI_API_KEY || process.env.PULSE_OPENAI_KEY;
    const model  = process.env.PULSE_OPENAI_MODEL || "gpt-4o-mini";

    // 0) Capado hard: fuera de tema -> respuesta cálida (sin preview)
    if (!userMsg || isOffTopic(userMsg)) {
      return res.status(200).json({
        mode: "offtopic",
        state: "feedback",
        text: offtopicReply(),
        mood: "neutral",
        meta: null
      });
    }

    const sectorGuess = sectorize(userMsg) || null;

    // 1) Si NO hay clave -> fallback humano local (solo por ausencia real de clave)
    if (!apiKey) {
      const human = craftHumanReply(userMsg, sectorGuess || undefined);
      return res.status(200).json({
        mode: "local",
        state: "cierre",
        text: human,
        mood: "celebrate",
        meta: { sector: sectorGuess, next_step: null }
      });
    }

    // 2) LIVE: GPT responde en tono humano + humor café. Sin artistas salvo eco del usuario.
    const system = [
      "Eres Pulse, socio creativo cercano y premium. SOLO ayudas con webs/negocios.",
      "Tono: humano, cálido y directo; guiños al café, sin pasarte; 1–3 frases.",
      "Haz una micro-pregunta útil para avanzar (título, sector, WhatsApp, CTA, etc.).",
      "No menciones artistas/marcas/personajes/cultura pop salvo que el usuario los mencione explícitamente.",
      "No hables de política/temas sensibles. Si el usuario se va del tema, redirígelo amablemente al proyecto web."
    ].join(" ");

    const r = await fetch("https://api.openai.com/v1/chat/completions", {
      method: "POST",
      headers: {
        "Authorization": `Bearer ${apiKey}`,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        model,
        temperature: 0.9,
        max_tokens: 220,
        messages: [
          { role: "system", content: system },
          { role: "user", content: userMsg }
        ]
      })
    });

    if (!r.ok) {
      // Fallback SOLO si la API falla de verdad
      const human = craftHumanReply(userMsg, sectorGuess || undefined);
      return res.status(200).json({
        mode: "local_error",
        state: "cierre",
        text: human,
        mood: "celebrate",
        meta: { sector: sectorGuess, next_step: null }
      });
    }

    const data = await r.json();
    const text: string =
      data?.choices?.[0]?.message?.content?.trim() ||
      craftHumanReply(userMsg, sectorGuess || undefined);

    return res.status(200).json({
      mode: "live",
      state: "cierre",
      text,
      mood: "celebrate",
      meta: { sector: sectorGuess, next_step: null }
    });
  } catch {
    const out = respondLocal("");
    return res.status(200).json({ mode: "local_catch", ...out });
  }
}
