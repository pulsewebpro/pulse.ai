export type ChatMsg = { role: "system" | "user" | "assistant"; content: string };

const TOKENS_ESTIMATED_PER_CHAR = 0.25; // aproximación conservadora

/**
 * Recorta historial manteniendo:
 * - El último bloque de usuario+asistente
 * - Mensajes más recientes hasta ~N tokens
 * - Nunca rompe el mensaje más reciente
 */
export function trimHistory(messages: ChatMsg[], maxTokens = 2200): ChatMsg[] {
  if (!messages?.length) return [];
  const kept: ChatMsg[] = [];
  let budget = maxTokens;

  // Mantener siempre el último mensaje del usuario (y el último del assistant si existe antes)
  const last = messages[messages.length - 1];
  budget -= estimateTokens(last.content);
  kept.unshift(last);

  // Recorremos hacia atrás, sin incluir el último ya añadido
  for (let i = messages.length - 2; i >= 0; i--) {
    const m = messages[i];
    const t = estimateTokens(m.content);
    if (t <= budget) {
      kept.unshift(m);
      budget -= t;
    } else {
      // Paramos al llegar al límite; dejamos que el system prompt se inyecte fuera
      break;
    }
  }
  return kept;
}

function estimateTokens(text: string) {
  return Math.ceil((text || "").length * TOKENS_ESTIMATED_PER_CHAR);
}
