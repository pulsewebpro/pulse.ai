/* ✨ Pulse Chat · Escala armonizada (solo estética) */

/* --- Variables de escala --- */
:root{
  --radius: 14px;
  --spacing: 12px;
  --chip-h: 44px;
  --chip-fs: 14px;
  --icon: 22px;
  --input-h: 50px;
  --panelR-w: 340px;     /* md */
  --panelR-w-lg: 360px;  /* >=1280px */
}

/* --- Layout base --- */
.chat-layout{
  display:flex;gap:24px;min-height:100vh;padding:24px;
  background:
    radial-gradient(1000px 500px at 15% -10%, rgba(56,189,248,.08), transparent 60%),
    radial-gradient(900px 500px at 85% 110%, rgba(88,28,135,.10), transparent 55%),
    linear-gradient(180deg,#0b1020,#000);
}

/* Columna izquierda (Pulse) */
.pulse-avatar{width:90px;display:flex;flex-direction:column;align-items:center;justify-content:flex-end}
.pulse-avatar img{width:64px;height:64px;object-fit:contain;filter:drop-shadow(0 8px 18px rgba(56,189,248,.35))}
.pulse-avatar .bubble{
  font-size:12px;line-height:1.2;color:#F8FAFC;opacity:.85;margin-top:8px;
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);
  padding:6px 8px;border-radius:10px;text-align:center;backdrop-filter:blur(6px);
}

/* Columna central (Chat) */
.chat-panel{
  flex:1;display:flex;flex-direction:column;padding:16px;border-radius:var(--radius);
  background:rgba(0,0,0,.85);border:1px solid rgba(255,255,255,.12);backdrop-filter:blur(10px)
}
.chat-panel h1{font-size:18px;font-weight:800;margin:0 0 10px}
.chat-bubble-pulse,.chat-bubble-user{border-radius:12px;padding:10px;margin-bottom:8px;max-width:80%}
.chat-bubble-pulse{color:#fff;border:1px solid #38BDF8;background:rgba(56,189,248,.18)}
.chat-bubble-user{color:#F8FAFC;border:1px solid rgba(255,255,255,.25);background:rgba(255,255,255,.06)}
.chat-input{
  width:100%;height:var(--input-h);padding:0 16px;border-radius:12px;background:rgba(0,0,0,.6);
  color:#fff;border:1px solid #FFD700;outline:none;font-size:14px
}
.chat-input::placeholder{color:#d1d5db}
.chat-input:focus{box-shadow:0 0 12px #38BDF8;border-color:#38BDF8}
.chat-button{
  height:var(--input-h);padding:0 18px;border:none;border-radius:12px;cursor:pointer;
  font-weight:800;color:#fff;background:linear-gradient(90deg,#FFD700,#FF9F45);
  box-shadow:0 0 14px rgba(56,189,248,.45);transition:transform .12s ease
}
.chat-button:hover{transform:scale(1.04)}
.chat-button:active{transform:scale(.97)}

/* Columna derecha (Generador) */
.generator-card{
  width:var(--panelR-w);max-width:100%;
  display:flex;flex-direction:column;padding:16px;border-radius:var(--radius);
  background:rgba(10,10,20,.9);border:1px solid rgba(255,255,255,.10)
}
.generator-card h2{font-size:16px;font-weight:800;margin:0 0 10px}

/* Chips: tamaño consistente y legible */
.chips-grid{display:grid;grid-template-columns:1fr;gap:10px}
.chip-button{
  display:flex;align-items:center;gap:10px;width:100%;height:var(--chip-h);
  padding:0 14px;border-radius:9999px;font-weight:700;font-size:var(--chip-fs);color:#0A0A0A;
  background:linear-gradient(180deg,#f7f9fc,#e5ecf3);border:1px solid rgba(255,255,255,.75);
  box-shadow:0 6px 14px rgba(0,0,0,.22),0 0 14px rgba(56,189,248,.22);transition:transform .1s ease
}
.chip-button:hover{transform:translateY(-1px)}
.chip-emoji{
  display:inline-grid;place-items:center;width:var(--icon);height:var(--icon);border-radius:9999px;
  background:radial-gradient(circle at 30% 30%,#fff,#e8eef6);box-shadow:inset 0 1px 0 rgba(255,255,255,.9)
}

/* Preview: más respiración */
.preview-box{
  margin-top:12px;display:flex;align-items:center;justify-content:center;color:#fff;border-radius:12px;
  background:rgba(5,8,15,.92) url('/banner/banner-spark-overlay.png') center/cover no-repeat;
  border:1px solid rgba(255,255,255,.16);min-height:220px;
  box-shadow:0 0 18px rgba(56,189,248,.12),inset 0 0 30px rgba(10,14,30,.5)
}

/* --- Responsive --- */
@media (min-width:1280px){
  .generator-card{width:var(--panelR-w-lg)}
}
@media (max-width:1024px){
  :root{ --panelR-w: 320px }
}
@media (max-width:900px){
  .chat-layout{flex-direction:column}
  .pulse-avatar{order:0;width:auto;flex-direction:row;justify-content:flex-start;gap:8px}
  .pulse-avatar img{width:56px;height:56px}
  .generator-card{width:100%}
}
