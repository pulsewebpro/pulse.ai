import '../styles/chat.css';
import { useEffect, useRef, useState } from "react";

type Msg = { role: "user" | "assistant"; content: string };
type Meta = { ms?: number; usage?: { prompt_tokens?: number; completion_tokens?: number; total_tokens?: number }; cost_eur?: number } | null;

export default function Chat() {
  const [msgs, setMsgs] = useState<Msg[]>([
    {
      role: "assistant",
      content:
        "Estoy contigo. Cuéntame tu idea de web/negocio como si estuviéramos tomando un café. Te escucho y la aterrizo en una propuesta clara. ¿Qué quieres lograr primero: vender, reservas o leads? ☕⚡",
    },
  ]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const [meta, setMeta] = useState<Meta>(null);
  const scrollRef = useRef<HTMLDivElement>(null);
  const abortRef = useRef<AbortController | null>(null);

  useEffect(() => {
    scrollRef.current?.scrollTo({ top: scrollRef.current.scrollHeight, behavior: "smooth" });
  }, [msgs, loading]);

  function softLimit(text: string) {
    const t = text.trim().slice(0, 5000); // mismo hard cap que server
    return t;
  }

  async function send() {
    const text = softLimit(input);
    if (!text || loading) return;

    // Cancelar petición anterior si existiera
    if (abortRef.current) abortRef.current.abort();
    const controller = new AbortController();
    abortRef.current = controller;

    const next = [...msgs, { role: "user" as const, content: text }];
    setMsgs(next);
    setInput("");
    setLoading(true);
    setMeta(null);

    const started = Date.now();

    try {
      const res = await fetch("/api/pulse", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        signal: controller.signal,
        body: JSON.stringify({
          messages: next.map((m) => ({ role: m.role, content: m.content })),
        }),
      });

      const data = await res.json();
      const assistant = data?.content || "…";
      setMsgs([...next, { role: "assistant", content: assistant }]);

      const elapsed = Date.now() - started;
      const serverMs: number = data?.meta?.ms ?? elapsed;
      const usage = data?.meta?.usage || null;
      const cost_eur = data?.meta?.cost_eur ?? 0;
      setMeta({ ms: serverMs, usage, cost_eur });
    } catch (e: any) {
      if (e?.name === "AbortError") {
        setMsgs([
          ...next,
          { role: "assistant", content: "Corté la respuesta anterior para priorizar tu último mensaje. Sigo contigo. ☕" },
        ]);
      } else {
        setMsgs([
          ...next,
          {
            role: "assistant",
            content:
              "Oops, casi derramo el café. Ha fallado la conexión un segundo. Probemos de nuevo y sigo contigo. ☕",
          },
        ]);
      }
    } finally {
      setLoading(false);
      abortRef.current = null;
    }
  }

  const renderContent = (text: string) => {
    return <div style={{ whiteSpace: "pre-wrap" }}>{text}</div>;
  };

  return (
    <main
      style={{
        minHeight: "100vh",
        background: "#0A0A0A",
        color: "#F8FAFC",
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        padding: "24px",
      }}
    >
      <h1 style={{ fontSize: "28px", fontWeight: 800, marginBottom: 16 }}>Chat con Pulse</h1>

      <div
        ref={scrollRef}
        style={{
          width: "100%",
          maxWidth: 860,
          height: "64vh",
          overflowY: "auto",
          padding: 16,
          background: "rgba(255,255,255,0.04)",
          border: "1px solid rgba(56,189,248,0.25)",
          borderRadius: 16,
          boxShadow: "0 10px 30px rgba(0,0,0,0.35)",
        }}
        aria-live="polite"
      >
        <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
          {msgs.map((m, i) => (
            <div
              key={i}
              style={{
                alignSelf: m.role === "user" ? "flex-end" : "flex-start",
                background:
                  m.role === "user" ? "rgba(255,255,255,0.08)" : "rgba(56,189,248,0.10)",
                border: "1px solid rgba(56,189,248,0.28)",
                padding: "12px 14px",
                borderRadius: 14,
                maxWidth: "72%",
                lineHeight: 1.5,
              }}
            >
              {renderContent(m.content)}
            </div>
          ))}
          {loading && (
            <div
              style={{
                alignSelf: "flex-start",
                background: "rgba(56,189,248,0.10)",
                border: "1px solid rgba(56,189,248,0.28)",
                padding: "12px 14px",
                borderRadius: 14,
                maxWidth: "72%",
                fontStyle: "italic",
                opacity: 0.9,
              }}
            >
              Pensando tu mejor versión… ☕
            </div>
          )}
        </div>
      </div>

      <div
        style={{
          display: "flex",
          gap: 10,
          width: "100%",
          maxWidth: 860,
          marginTop: 14,
          alignItems: "center",
        }}
      >
        <input
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyDown={(e) => {
            if (e.key === "Enter" && !e.shiftKey && input.trim() && !loading) {
              e.preventDefault();
              send();
            }
            if (e.key === "Escape" && abortRef.current) {
              abortRef.current.abort();
            }
          }}
          placeholder="Háblame como a un amigo, yo diseño tu web… (Shift+Enter salto de línea · Esc cancela)"
          aria-label="Escribe tu idea"
          style={{
            flex: 1,
            padding: "14px 16px",
            borderRadius: 12,
            border: "1px solid rgba(255,215,0,0.45)",
            background: "rgba(255,255,255,0.06)",
            color: "#F8FAFC",
            outline: "none",
            boxShadow: "inset 0 0 0 1px rgba(56,189,248,0.12)",
          }}
        />
        <button
          onClick={send}
          disabled={!input.trim() || !input || loading}
          style={{
            padding: "12px 18px",
            borderRadius: 14,
            border: "1px solid rgba(255,215,0,0.6)",
            background: "linear-gradient(135deg,#FFD700,#FF9F45)",
            color: "#0A0A0A",
            fontWeight: 800,
            cursor: loading ? "not-allowed" : "pointer",
            transform: loading ? "scale(0.98)" : "scale(1)",
          }}
          aria-busy={loading}
        >
          {loading ? "Creando…" : "Enviar"}
        </button>
      </div>

      <div style={{ marginTop: 10, color: "rgba(248,250,252,0.7)", fontSize: 12 }}>
        {meta ? (
          <span>
            Latencia: <strong>{meta.ms} ms</strong> · Tokens in/out:{" "}
            <strong>{meta.usage?.prompt_tokens || 0}/{meta.usage?.completion_tokens || 0}</strong>{" "}
            · Coste≈ <strong>{(meta.cost_eur || 0).toFixed(4)} €</strong>
          </span>
        ) : (
          <span>Enter para enviar • Shift+Enter salto de línea • Esc para cancelar respuesta</span>
        )}
      </div>
    </main>
  );
}
