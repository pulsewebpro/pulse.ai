/* ✨ Pulse Chat Premium Skin (Pixar × Tesla × Apple) */
/* Variables */
:root{
  --radius: 14px;
  --gap: 24px;
  --chip-h: 36px;
  --chip-fs: 13px;
  --icon: 18px;
  --input-h: 46px;
  --panelR-w: 300px;
  --panelR-w-lg: 320px;
  --avatar: 120px;
  --bubble-fs: 13px;
}

/* Layout */
.chat-layout{
  display:flex; gap:var(--gap); min-height:100vh; padding:24px;
  background:linear-gradient(180deg,#06080f 0%,#000 100%);
}

/* Pulse avatar */
.pulse-avatar{
  width:calc(var(--avatar) + 30px);
  display:flex; flex-direction:column; align-items:center; justify-content:flex-end;
  margin-bottom:40px;
}
.pulse-avatar img{
  width:var(--avatar); height:var(--avatar); object-fit:contain;
  filter:drop-shadow(0 0 25px rgba(56,189,248,.5));
  animation:pulse-glow 3s infinite alternate;
}
@keyframes pulse-glow{
  from{filter:drop-shadow(0 0 15px rgba(56,189,248,.3));}
  to{filter:drop-shadow(0 0 30px rgba(56,189,248,.6));}
}
.pulse-avatar .bubble{
  font-size:var(--bubble-fs); color:#F8FAFC; opacity:.9; margin-top:10px;
  background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.18);
  padding:6px 10px; border-radius:12px; text-align:center;
  backdrop-filter:blur(8px); box-shadow:0 4px 10px rgba(0,0,0,.4);
}

/* Chat panel */
.chat-panel{
  flex:1; display:flex; flex-direction:column; padding:18px; border-radius:var(--radius);
  background:rgba(12,14,20,.85); border:1px solid rgba(255,255,255,.08); backdrop-filter:blur(12px);
  box-shadow:inset 0 0 30px rgba(56,189,248,.06);
}
.chat-panel h1{font-size:16px;font-weight:800;margin:0 0 12px;}
.chat-bubble-pulse,.chat-bubble-user{border-radius:14px;padding:10px 14px;margin-bottom:10px;max-width:80%;}
.chat-bubble-pulse{
  color:#fff;background:rgba(56,189,248,.15);border:1px solid #38BDF8;
  box-shadow:0 0 15px rgba(56,189,248,.3);
}
.chat-bubble-user{
  color:#F8FAFC;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.2);
  box-shadow:inset 0 0 12px rgba(255,255,255,.05);
}

/* Input + button */
.chat-input{
  width:100%;height:var(--input-h);padding:0 16px;border-radius:14px;
  background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.2);
  font-size:13px;backdrop-filter:blur(6px);
}
.chat-input::placeholder{color:#a0a7b3;}
.chat-input:focus{box-shadow:0 0 12px #38BDF8;border-color:#38BDF8;}
.chat-button{
  height:var(--input-h);padding:0 18px;border:none;border-radius:14px;cursor:pointer;
  font-weight:800;font-size:13px;color:#fff;
  background:linear-gradient(90deg,#FFD700,#FF9F45); box-shadow:0 0 15px rgba(56,189,248,.5);
  transition:transform .15s ease, box-shadow .15s ease;
}
.chat-button:hover{transform:scale(1.05);box-shadow:0 0 20px rgba(56,189,248,.7);}
.chat-button:active{transform:scale(.96);}

/* Right panel */
.generator-card{
  width:var(--panelR-w);max-width:100%;
  display:flex;flex-direction:column;padding:16px;border-radius:var(--radius);
  background:linear-gradient(180deg,#0b1020 0%,#000 100%);
  border:1px solid rgba(255,255,255,.1);
  box-shadow:0 0 25px rgba(56,189,248,.1);
}
.generator-card h2{font-size:15px;font-weight:800;margin:0 0 12px;text-shadow:0 0 10px rgba(56,189,248,.3);}

/* Chips */
.chips-grid{display:grid;grid-template-columns:1fr;gap:10px;}
.chip-button{
  display:flex;align-items:center;gap:10px;width:100%;height:var(--chip-h);
  padding:0 12px;border-radius:9999px;font-weight:700;font-size:var(--chip-fs);color:#0A0A0A;
  background:linear-gradient(180deg,#f4f6fa,#dfe6ef);
  border:1px solid rgba(255,255,255,.7);
  box-shadow:0 4px 10px rgba(0,0,0,.25),0 0 12px rgba(56,189,248,.2);
  transition:transform .12s ease, box-shadow .15s ease;
}
.chip-button:hover{
  transform:translateY(-1px);
  box-shadow:0 6px 14px rgba(0,0,0,.3),0 0 16px rgba(56,189,248,.35);
}
.chip-button.active{
  border:2px solid #38BDF8; box-shadow:0 0 20px rgba(56,189,248,.5);
}
.chip-emoji{
  display:inline-grid;place-items:center;width:var(--icon);height:var(--icon);
  border-radius:9999px;background:radial-gradient(circle at 30% 30%,#fff,#e9eef6);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.9);
}

/* Preview */
.preview-box{
  margin-top:14px;display:flex;align-items:center;justify-content:center;color:#fff;border-radius:14px;
  background:rgba(5,8,15,.9) url('/banner/banner-spark-overlay.png') center/cover no-repeat;
  border:1px solid rgba(255,255,255,.15);min-height:230px;
  box-shadow:0 0 20px rgba(56,189,248,.15),inset 0 0 30px rgba(10,14,30,.6);
}

/* Responsive */
@media(min-width:1280px){.generator-card{width:var(--panelR-w-lg);}}
@media(max-width:900px){
  .chat-layout{flex-direction:column;}
  .pulse-avatar{order:0;width:auto;flex-direction:row;justify-content:flex-start;gap:10px;}
  .pulse-avatar img{width:100px;height:100px;}
  .generator-card{width:100%;}
}
